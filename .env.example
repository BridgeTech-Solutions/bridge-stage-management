# ------------------------------------------------------------------
# Variables d'environnement — Bridge (gestion des demandes de stage)
# Copier ce fichier en `.env` et renseigner les vraies valeurs.
# NE JAMAIS committer le fichier `.env` (déjà ignoré par git).
# ------------------------------------------------------------------

# --- Base de données PostgreSQL (Prisma) ---
# Avec Supabase, deux URLs (bouton "Connect" du dashboard) :
#  - DATABASE_URL : pooler "Transaction" (port 6543) + ?pgbouncer=true  -> l'app
#  - DIRECT_URL   : pooler "Session" (port 5432)                        -> les migrations
DATABASE_URL="postgresql://postgres.[REF]:[MOT_DE_PASSE]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[MOT_DE_PASSE]@aws-0-[region].pooler.supabase.com:5432/postgres"
# En local (Postgres/Docker), mets la MÊME valeur dans les deux, ex. :
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bridge?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bridge?schema=public"

# --- NextAuth (Auth.js) ---
# Générer un secret : `npx auth secret` ou `openssl rand -base64 32`
AUTH_SECRET="change-me-en-un-secret-aleatoire"
# URL de base de l'app (en prod : l'URL Vercel)
AUTH_URL="http://localhost:3000"

# --- Supabase Storage (documents des candidats) ---
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="votre-cle-service-role-supabase"
SUPABASE_STORAGE_BUCKET="documents"

# --- Email (notifications — à brancher en Slice 4) ---
# Ex. avec Resend : créer une clé sur https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="Bridge <no-reply@exemple.com>"
